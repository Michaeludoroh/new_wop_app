# General
NODE_ENV=development

# Database
POSTGRES_USER=ministry
POSTGRES_PASSWORD=ministry_password
POSTGRES_DB=ministry_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ministry:ministry_password@localhost:5432/ministry_platform?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_ADAPTER_ENABLED=true

# API
API_PORT=4000
PORT=4000
JWT_ACCESS_SECRET=replace_with_strong_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=100
CORS_ORIGIN=http://localhost:3001
METRICS_AUTH_TOKEN=

# Websocket
WEBSOCKET_PORT=4100
WEBSOCKET_ONLY_MODE=false
NEXT_PUBLIC_WEBSOCKET_URL=http://localhost:4100

# Admin web
ADMIN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Notifications / Push — use ONE credential option (checked in order: JSON env → file → split)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Payment providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYMENT_REDIRECT_BASE_URL=http://localhost:4000/api/v1
