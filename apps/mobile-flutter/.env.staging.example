# Staging mobile build configuration template
# Mobile reads API_BASE_URL via --dart-define at build time (see scripts/beta/build-mobile-staging.mjs)
APP_ENV=staging

# Replace with your staging API host
API_BASE_URL=https://staging-api.example.com/api/v1

# Informational only — native Firebase config comes from google-services.json / GoogleService-Info.plist
FIREBASE_PROJECT_ID=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
