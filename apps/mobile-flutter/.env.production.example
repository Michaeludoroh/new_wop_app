# Flutter mobile production build template
# Pass values via --dart-define at build time (see scripts/beta/build-mobile-production.mjs)

APP_ENV=production

# Required for release/profile builds
API_BASE_URL=https://api.example.com/api/v1

# Native in-app purchase product IDs
MOBILE_ANDROID_PREMIUM_PRODUCT_ID=wopp_premium_monthly
MOBILE_IOS_PREMIUM_PRODUCT_ID=wopp_premium_monthly

# Optional store listing URL overrides (defaults derive from API_BASE_URL + support email)
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
SUPPORT_URL=
SUPPORT_EMAIL=support@wopp.org
