# Flutter mobile app environment template
APP_ENV=development

# API endpoint (debug default uses emulator loopback via ApiConfig)
API_BASE_URL=http://localhost:4000/api/v1

# Store listing / legal URLs (optional --dart-define overrides)
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
SUPPORT_URL=
SUPPORT_EMAIL=support@wopp.org

# Firebase mobile (integration-ready placeholders)
FIREBASE_PROJECT_ID=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=

# Payments public keys (website checkout only — mobile uses native IAP)
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# Native in-app purchase product IDs (pass via --dart-define at build time)
MOBILE_ANDROID_PREMIUM_PRODUCT_ID=wopp_premium_monthly
MOBILE_IOS_PREMIUM_PRODUCT_ID=wopp_premium_monthly
