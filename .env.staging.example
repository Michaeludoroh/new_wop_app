# General
NODE_ENV=staging

# Database
POSTGRES_USER=staging_user
POSTGRES_PASSWORD=staging_password
POSTGRES_DB=ministry_platform_staging
DATABASE_URL=postgresql://staging_user:staging_password@staging-db-host:5432/ministry_platform_staging?schema=public

# Redis
REDIS_URL=redis://staging-redis-host:6379
REDIS_ADAPTER_ENABLED=true

# API
API_PORT=4000
PORT=4000
JWT_ACCESS_SECRET=replace_with_staging_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_staging_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=120
CORS_ORIGIN=https://staging-admin.example.com
METRICS_AUTH_TOKEN=replace_with_staging_metrics_token

# Websocket
WEBSOCKET_PORT=4100
WEBSOCKET_ONLY_MODE=false
NEXT_PUBLIC_WEBSOCKET_URL=https://staging-ws.example.com

# Admin web
ADMIN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=https://staging-api.example.com/api/v1

# Notifications / Push — use ONE credential option (checked in order: JSON env → file → split)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Email (provider-agnostic)
EMAIL_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=WOPP
APP_NAME=Ministry Platform
WEB_APP_URL=https://staging-admin.example.com

# Content access tokens (eBook streaming)
CONTENT_ACCESS_SECRET=replace_with_staging_content_access_secret_at_least_32_chars
API_PUBLIC_URL=https://staging-api.example.com

# Payment providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYMENT_REDIRECT_BASE_URL=https://staging-api.example.com/api/v1
