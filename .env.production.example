# General
NODE_ENV=production

# Database (managed)
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=prod_password
POSTGRES_DB=ministry_platform
DATABASE_URL=postgresql://prod_user:prod_password@prod-db-host:5432/ministry_platform?schema=public

# Redis (managed)
REDIS_URL=redis://prod-redis-host:6379
REDIS_ADAPTER_ENABLED=true

# API
API_PORT=4000
PORT=4000
JWT_ACCESS_SECRET=replace_with_prod_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_prod_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=80
CORS_ORIGIN=https://admin.example.com
METRICS_AUTH_TOKEN=replace_with_prod_metrics_token

# Websocket
WEBSOCKET_PORT=4100
WEBSOCKET_ONLY_MODE=false
NEXT_PUBLIC_WEBSOCKET_URL=https://ws.example.com

# Admin web
ADMIN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1

# Notifications / Push
FIREBASE_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Payment providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYMENT_REDIRECT_BASE_URL=https://api.example.com/api/v1
