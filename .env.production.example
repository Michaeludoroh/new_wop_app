# General
NODE_ENV=production

# Database (managed or compose postgres service)
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=replace_with_strong_postgres_password
POSTGRES_DB=ministry_platform
DATABASE_URL=postgresql://prod_user:replace_with_strong_postgres_password@postgres:5432/ministry_platform?schema=public

# Redis (managed or compose redis service)
REDIS_URL=redis://redis:6379
REDIS_ADAPTER_ENABLED=true

# API
API_PORT=4000
PORT=4000
JWT_ACCESS_SECRET=replace_with_prod_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_prod_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=80
CORS_ORIGIN=https://admin.example.com
METRICS_AUTH_TOKEN=replace_with_prod_metrics_token

# Content access (eBook streaming tokens)
CONTENT_ACCESS_SECRET=replace_with_prod_content_access_secret_at_least_32_chars
API_PUBLIC_URL=https://api.example.com

# Websocket
WEBSOCKET_PORT=4100
WEBSOCKET_ONLY_MODE=false
NEXT_PUBLIC_WEBSOCKET_URL=https://ws.example.com

# Admin web
ADMIN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1

# Notifications / Push — use ONE credential option
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
APP_NAME=WOP Ministry Platform
WEB_APP_URL=https://admin.example.com

# Payment providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYMENT_REDIRECT_BASE_URL=https://api.example.com/api/v1

# Optional observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Deploy metadata (set by CI/deploy script)
IMAGE_TAG=latest
