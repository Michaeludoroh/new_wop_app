# API service environment template
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://ministry:ministry_password@localhost:5432/ministry_platform?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_ADAPTER_ENABLED=true

# Auth (canonical values are in the repo root ../../.env — do not duplicate conflicting JWT secrets here)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# HTTP
CORS_ORIGIN=http://localhost:3001
METRICS_AUTH_TOKEN=

# Firebase / FCM — use ONE of the credential options below (checked in order)
# Option A: inline service account JSON (CI / staging / production secrets)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option A2: path to downloaded service account JSON (local dev; relative to API cwd or services/api/)
FIREBASE_SERVICE_ACCOUNT_FILE=ministry-mobile-firebase-adminsdk-fbsvc-d1b31b3ebf.json
# Option B: split credentials (alternative to JSON env / file)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Payments (integration-ready placeholders)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYMENT_REDIRECT_BASE_URL=http://localhost:4000/api/v1

# Mobile store billing (Google Play + Apple IAP)
GOOGLE_PLAY_PACKAGE_NAME=com.ministrymobile.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
MOBILE_ANDROID_PREMIUM_PRODUCT_ID=wopp_premium_monthly
APPLE_SHARED_SECRET=
APPLE_USE_SANDBOX=true
MOBILE_IOS_PREMIUM_PRODUCT_ID=wopp_premium_monthly

# Email (provider-agnostic — set EMAIL_PROVIDER to switch vendors without code changes)
EMAIL_PROVIDER=mock
# Supported: mock | brevo | aws | sendgrid | mailgun | postmark | smtp
# Production example (Brevo):
# EMAIL_PROVIDER=brevo
# SMTP_HOST=smtp-relay.brevo.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=WOPP
# Legacy aliases still supported: SMTP_USER, SMTP_PASS, SMTP_FROM
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=30000
SMTP_POOL_MAX_CONNECTIONS=5
SMTP_MAX_RETRIES=3
SMTP_RETRY_DELAY_MS=1000
CONTACT_ADMIN_EMAIL=
SUPPORT_EMAIL=
APP_NAME=Ministry Platform
WEB_APP_URL=http://localhost:3001
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
EMAIL_LOGO_URL=

# Content access tokens (eBook streaming)
CONTENT_ACCESS_SECRET=replace_with_strong_content_access_secret_at_least_32_chars
API_PUBLIC_URL=http://localhost:4000
